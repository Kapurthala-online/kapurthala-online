# Kapurthala Online — Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development

# MongoDB — replace with your Atlas connection string for production
MONGODB_URI=mongodb://127.0.0.1:27017/kapurthala_online

# JWT Secret — use a long random string in production
JWT_SECRET=kapurthala-online-super-secret-jwt-key-change-in-production

# Admin credentials (used for seeding default admin)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=kapurthala2024

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
